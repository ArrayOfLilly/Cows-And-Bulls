    "learn.objective.line2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Both the sequence length (3...8) and the maximum number of guesses are configurable in Settings."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A sorozat hossza (3...8) és a maximális tippszám is szabadon állítható a Beállításokban."

    },
    "help.settings.enable_game_time_limit": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If enabled, the whole game must finish before this timer expires."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ha be van kapcsolva, a teljes játékot be kell fejezni, mielőtt ez az idő lejár."
          }
        }
      }
    },
    "help.settings.enable_hard_mode": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This shows the cows and bulls score for only the most recent guess."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Csak a legutóbbi tipp tehén-bika eredményét mutatja."

    "learn.how_to_play.line1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app generates a hidden digit sequence. You can set its length between 3 and 8."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az app egy rejtett számsort generál. Ennek hossza 3 és 8 számjegy között állítható."
          }
        }
      }
    },
    "learn.how_to_play.line2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Digits are from 0 to 9. You can choose whether repeated digits are allowed."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A számjegyek 0 és 9 közöttiek. Beállíthatod, hogy az ismétlődés engedélyezett legyen-e."
          }
        }
      }
    },
    "learn.how_to_play.line3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Code-breaker makes the first guess."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kódfeltörő megteszi az első tippet."
          }
        }
      }
    },
    "learn.objective.line1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The objective is to guess the hidden digit sequence generated by the app."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A cél az app által generált rejtett számsor kitalálása."
          }
        }
      }

    },
    "learn.score.base_intro": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your base score depends on the mathematical difficulty of the game, calculated from the number of possible secret codes."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az alappontszám a játék matematikai nehézségétől függ, amelyet a lehetséges titkos kódok száma alapján számolunk."
          }
        }
      }
    },
    "learn.score.difficulty_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Difficulty multipliers apply for:"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nehézségi szorzók járnak az alábbiakért:"
          }
        }
      }
    },
    "learn.score.difficulty.guess_limit": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Limited number of guesses: ×max(1.0, (3 × code length) / max guesses)"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "• Limitált tippszám: ×max(1.0, (3 × kódhossz) / max tippszám)"
          }
        }
      }
    },
    "learn.score.difficulty.hard": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Hard mode (only last feedback visible): ×1.40"

    "learn.strategy.line1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep track of which numbers have been confirmed or eliminated, and which positions might be correct."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kövesd, mely számok igazolódtak vagy estek ki, és mely pozíciók lehetnek jók."
          }

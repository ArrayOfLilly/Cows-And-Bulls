      }
    },
    "learn.strategy.line2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The code-breaker keeps making guesses, one per turn, using feedback to narrow the possibilities."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kódfeltörő körönként tippel, és a visszajelzés alapján szűkíti a lehetőségeket."
          }
        }
      }
    },
    "learn.strategy.line3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You win by matching the full sequence before you run out of allowed guesses."

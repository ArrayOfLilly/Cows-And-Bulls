    "%@: ": {
      "comment": "A text field displaying a guess number followed by a colon.",
      "isCommentAutoGenerated": true
    },
    "%lld%%": {
      "comment": "A text view displaying the current volume of sound effects, shown as a percentage.",
      "isCommentAutoGenerated": true
    },
    "✅ %@": {
      "comment": "A label that indicates whether a game was won or lost. The text changes based on the `finalState` of the game. The argument is the string “history.state.won”.",
      "isCommentAutoGenerated": true
    },
    "❌ %@": {
      "comment": "A text label that indicates whether a game was won or lost. The text changes color based on the game's outcome. The argument is the string “history.state.lost”.",
      "isCommentAutoGenerated": true
    },
    "0": {
      "comment": "A placeholder text that appears when a guess does not contain any bulls or cows.",
      "isCommentAutoGenerated": true
    },
    "about.credits.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thanks for playing Cows and Bulls - I hope you enjoy the game!\n\n@ArrayOfLillies.com\n\nImage credits:\nDesigned by Freepik\nhttp://www.freepik.com\n\nMusic credits:\nMushroom Background Music by Sunsai\nhttps://freesound.org/s/415804/\nLicense: Attribution 4.0\n\nCandyworld Background Music by Sunsai\nhttps://freesound.org/s/415807/\nLicense: Attribution 4.0\n\nDesert background music by Sunsai\nhttps://freesound.org/s/415806/\nLicense: Attribution 4.0"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Köszönöm, hogy a Bika és Tehén játékkal játszol - remélem, tetszik!\n\n@ArrayOfLillies.com\n\nKép kredit:\nDesigned by Freepik\nhttp://www.freepik.com\n\nZene kredit:\nMushroom Background Music by Sunsai\nhttps://freesound.org/s/415804/\nLicenc: Attribution 4.0\n\nCandyworld Background Music by Sunsai\nhttps://freesound.org/s/415807/\nLicenc: Attribution 4.0\n\nDesert background music by Sunsai\nhttps://freesound.org/s/415806/\nLicenc: Attribution 4.0"
          }
        }
      }
    },
